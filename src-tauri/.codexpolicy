prefix_rule(pattern=["python3", "-c", "import pandas as pd\nfor p in ['/Users/zhaojimo/Downloads/excel开单/benchmark_result.xlsx','/Users/zhaojimo/Downloads/excel开单/benchmark_result2.xlsx']:\n    xls = pd.ExcelFile(p)\n    print('FILE:', p)\n    print('SHEETS:', xls.sheet_names)\n    for s in xls.sheet_names:\n        df = pd.read_excel(p, sheet_name=s)\n        print('\\nSHEET:', s)\n        print(df.head(10).to_string(index=False))\n        print('ROWS', len(df), 'COLS', list(df.columns))\n        print('-'*80)\n"], decision="allow")
prefix_rule(pattern=["python3", "-c", "from openpyxl import load_workbook\nfor p in ['/Users/zhaojimo/Downloads/excel开单/benchmark_result.xlsx','/Users/zhaojimo/Downloads/excel开单/benchmark_result2.xlsx']:\n    wb = load_workbook(p, read_only=True)\n    print('FILE:', p)\n    print('SHEETS:', wb.sheetnames)\n    for s in wb.sheetnames:\n        ws = wb[s]\n        print('\\nSHEET:', s)\n        rows = list(ws.iter_rows(values_only=True))\n        for row in rows[:10]:\n            print(row)\n        print('TOTAL_ROWS:', len(rows)-1 if rows else 0)\n    print('='*100)\n"], decision="allow")

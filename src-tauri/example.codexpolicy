# Example policy file using Starlark-like syntax
prefix_rule(["git", "*"], decision="allow")
prefix_rule(["npm", "install", "*"], decision="prompt")
prefix_rule(["rm", "-rf", "/"], decision="forbidden")
prefix_rule(["sudo", "*"], decision="prompt")

